{
  "alias": ["www.triangulatenews.com", "triangulatenews.com"],
  "crons": [
    {
      "path": "/api/ingest",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cluster",
      "schedule": "15,45 * * * *"
    },
    {
      "path": "/api/analyze",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/gci",
      "schedule": "5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
